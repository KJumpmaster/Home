import os
import requests
import yaml

USER = "KJumpmaster"
REPOS = ["Aircraft-Pics", "Real_Life_Aircraft_Pics"]
TOKEN = os.getenv("GH_TOKEN")

def get_image_list(repo):
    url = f"https://api.github.com/repos/{USER}/{repo}/contents/"
    headers = {"Authorization": f"token {TOKEN}"} if TOKEN else {}
    response = requests.get(url, headers=headers)
    # ... rest of the script from before ...
        # We only want common image formats
        return [file['name'] for file in response.json() 
                if file['name'].lower().endswith(('.png', '.jpg', '.jpeg', '.webp'))]
    else:
        print(f"Error accessing {repo}: {response.status_code}")
        return []

# Build the data structure
data_output = {}
for repo in REPOS:
    print(f"Cataloging {repo}...")
    data_output[repo.replace("-", "_")] = get_image_list(repo)

# Save to a YAML file for Jekyll
with open('aircraft_list.yml', 'w') as f:
    yaml.dump(data_output, f)

print("Success! 'aircraft_list.yml' is ready for your _data folder.")
