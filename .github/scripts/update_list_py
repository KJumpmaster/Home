import os
import yaml

# Path to your images and the data file
IMAGE_DIR = 'assets/images'
DATA_FILE = '_data/aircraft_list.yml'

def update_inventory():
    aircraft_list = []
    
    # Check if the images directory exists
    if not os.path.exists(IMAGE_DIR):
        print(f"Error: {IMAGE_DIR} not found.")
        return

    # Scan the folder for image files
    for filename in os.listdir(IMAGE_DIR):
        if filename.endswith(('.png', '.jpg', '.jpeg')):
            # Turn 'f16c.png' into 'F16C'
            name = os.path.splitext(filename)[0].replace('_', ' ').upper()
            aircraft_list.append({
                'name': name,
                'rank': 'TBD',
                'br': 'TBD',
                'radar_type': 'SCANNING...'
            })

    # Write the list to your _data folder
    os.makedirs(os.path.dirname(DATA_FILE), exist_ok=True)
    with open(DATA_FILE, 'w') as f:
        yaml.dump(aircraft_list, f, default_flow_style=False)
    
    print(f"Success: Updated {len(aircraft_list)} aircraft in inventory.")

if __name__ == "__main__":
    update_inventory()
